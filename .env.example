# Configurações do Banco de Dados PostgreSQL (Docker)
# Se estiver rodando via Docker Compose, mantenha o DB_HOST como 'database'
DB_HOST=database
DB_PORT=5432
DB_NAME=plano_aula_db
DB_USER=seu_usuario_aqui
DB_PASSWORD=sua_senha_aqui

# Chave da API de IA do Google (Pegue no Google AI Studio)
GEMINI_API_KEY=cole_sua_chave_do_gemini_aqui